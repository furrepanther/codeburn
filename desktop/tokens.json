    "brand": {
      "accent": "#C9521D",
      "accentDark": "#E8774A",
      "emberDeep": "#8B3E13",
      "emberGlow": "#F0A070",
      "bright": "#FF7A2A"
    },
    "surface": {
      "light": "#FAF7F3",
      "dark": "#1C1816",
      "elevated": "#FFFFFF",
      "elevatedDark": "#2A2320"
    },
    "text": {
      "primary": "#1C1816",
      "primaryDark": "#FAF7F3",
      "secondary": "#6E5D53",
      "secondaryDark": "#B5A49A",
      "tertiary": "#A0897D",
      "tertiaryDark": "#8A7A70"
    },
    "categorical": {
      "claude": "#C9521D",
      "cursor": "#4A7D5C",
      "codex": "#5C7CA3",
      "pi":     "#8B5A9C",
      "copilot":"#B8944C"
    }
